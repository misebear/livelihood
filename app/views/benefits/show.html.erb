<%# ── 혜택 상세 ── %>
<% content_for(:title) { "#{@benefit.title} — 수급생활" } %>

<div class="mb-4">
  <%= link_to benefits_path, class: "inline-flex items-center gap-1 text-sm text-slate-500 hover:text-indigo-600 transition" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    목록으로
  <% end %>
</div>

<section class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 mb-4">
  <div class="flex items-start gap-3 mb-4">
    <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0
      <%= @benefit.is_safe_savings ? 'bg-indigo-100' : 'bg-emerald-100' %>">
      <span class="text-lg"><%= @benefit.is_safe_savings ? '💰' : '📋' %></span>
    </div>
    <div>
      <h2 class="text-lg font-extrabold text-slate-800"><%= @benefit.title %></h2>
      <% if @benefit.is_safe_savings %>
        <span class="text-xs bg-indigo-100 text-indigo-700 font-bold px-2 py-0.5 rounded-full mt-1 inline-block">
          정부매칭 저축
        </span>
      <% end %>
    </div>
  </div>

  <% if @benefit.summary.present? %>
    <div class="bg-slate-50 rounded-xl p-4 mb-4">
      <p class="text-sm text-slate-700 leading-relaxed"><%= @benefit.summary %></p>
    </div>
  <% end %>

  <%# 신청 바로가기 %>
  <% if @benefit.apply_url.present? %>
    <%= link_to @benefit.apply_url, target: "_blank", rel: "noopener",
        class: "block w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-center font-bold py-3 rounded-xl shadow-sm hover:opacity-90 transition text-sm mb-4" do %>
      🔗 공식 신청 페이지 바로가기
    <% end %>
  <% end %>
</section>

<%# ── 관심등록 / 상태관리 ── %>
<section class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 mb-4">
  <h3 class="text-sm font-bold text-slate-700 mb-3">내 진행 상태</h3>

  <% if @user_benefit %>
    <div class="flex items-center gap-3 mb-4">
      <span class="text-sm text-slate-600">현재 상태:</span>
      <span class="text-sm font-bold px-3 py-1 rounded-full
        <%= case @user_benefit.status
            when 'interested'           then 'bg-blue-100 text-blue-700'
            when 'preparing_documents'   then 'bg-amber-100 text-amber-700'
            when 'applied'              then 'bg-emerald-100 text-emerald-700'
            end %>">
        <%= case @user_benefit.status
            when 'interested'           then '👀 관심'
            when 'preparing_documents'   then '📄 서류 준비 중'
            when 'applied'              then '✅ 신청 완료'
            end %>
      </span>
    </div>

    <div class="flex gap-2 flex-wrap">
      <% unless @user_benefit.status == 'preparing_documents' %>
        <%= button_to "📄 서류 준비 중으로 변경", user_benefit_path(@user_benefit, status: "preparing_documents"),
            method: :patch,
            class: "text-xs bg-amber-100 text-amber-700 font-bold px-3 py-2 rounded-xl hover:bg-amber-200 transition" %>
      <% end %>
      <% unless @user_benefit.status == 'applied' %>
        <%= button_to "✅ 신청 완료로 변경", user_benefit_path(@user_benefit, status: "applied"),
            method: :patch,
            class: "text-xs bg-emerald-100 text-emerald-700 font-bold px-3 py-2 rounded-xl hover:bg-emerald-200 transition" %>
      <% end %>
      <%= button_to "관심 해제", user_benefit_path(@user_benefit),
          method: :delete,
          class: "text-xs bg-red-50 text-red-600 font-bold px-3 py-2 rounded-xl hover:bg-red-100 transition",
          data: { turbo_confirm: "정말 관심 목록에서 제거할까요?" } %>
    </div>
  <% else %>
    <p class="text-sm text-slate-500 mb-3">이 혜택을 관심 목록에 추가하세요.</p>
    <%= button_to "⭐ 관심 등록", user_benefits_path(benefit_id: @benefit.id),
        method: :post,
        class: "bg-indigo-600 text-white text-sm font-bold px-5 py-2.5 rounded-xl hover:bg-indigo-700 transition shadow-sm" %>
  <% end %>
</section>

<%= render_disclaimer(type: :benefit) %>
