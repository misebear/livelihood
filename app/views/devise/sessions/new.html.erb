<%# ── 로그인 — Stitch 디자인 기반 프리미엄 UI ── %>
<% content_for(:title) { "로그인 — 보듬" } %>

<div class="devise-container">
  <%# ── 히어로 섹션 ── %>
  <div class="devise-hero">
    <div class="devise-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="color:white;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
      </svg>
    </div>
    <h1>보듬</h1>
    <p>현금흐름 & 안전 자산 관리</p>
  </div>

  <%# ── 로그인 폼 ── %>
  <div class="devise-form">
    <div class="devise-form-card">
      <h2>로그인</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="field">
          <%= f.label :email, "이메일" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "이메일 주소를 입력하세요" %>
        </div>

        <div class="field">
          <%= f.label :password, "비밀번호" %>
          <%= f.password_field :password, autocomplete: "current-password",
              placeholder: "비밀번호를 입력하세요" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="checkbox-row">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, "로그인 유지" %>
          </div>
        <% end %>

        <div class="actions">
          <%= f.submit "로그인" %>
        </div>
      <% end %>

      <%# ── Google 소셜 로그인 ── %>
      <% if devise_mapping.omniauthable? && resource_class.omniauth_providers.include?(:google_oauth2) %>
        <div class="devise-separator">
          <span>또는</span>
        </div>

        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, class: "google-login-btn", data: { turbo: false } do %>
          <svg class="google-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Google로 로그인
        <% end %>
      <% end %>

      <div class="devise-links">
        <%= link_to "회원가입", new_registration_path(resource_name) %>
        <%= link_to "비밀번호 찾기", new_password_path(resource_name) %>
      </div>
    </div>
  </div>

  <div class="devise-footer">
    기초생활수급자를 위한 현금흐름 관리 서비스
  </div>
</div>
