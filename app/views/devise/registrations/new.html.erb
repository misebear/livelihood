<%# ── 회원가입 — Stitch 디자인 기반 ── %>
<% content_for(:title) { "회원가입 — 보듬" } %>

<div class="devise-container">
  <div class="devise-hero">
    <div class="devise-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="color:white;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" />
      </svg>
    </div>
    <h1>보듬</h1>
    <p>새 계정 만들기</p>
  </div>

  <div class="devise-form">
    <div class="devise-form-card">
      <h2>회원가입</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <% if resource.errors.any? %>
          <div class="devise-error-box">
            <p class="devise-error-title">오류가 있습니다:</p>
            <ul class="devise-error-list">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="field">
          <%= f.label :email, "이메일" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "이메일 주소" %>
        </div>

        <div class="field">
          <%= f.label :password, "비밀번호" %>
          <%= f.password_field :password, autocomplete: "new-password",
              placeholder: "6자 이상" %>
        </div>

        <div class="field">
          <%= f.label :password_confirmation, "비밀번호 확인" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              placeholder: "비밀번호를 다시 입력" %>
        </div>

        <div class="actions">
          <%= f.submit "회원가입" %>
        </div>
      <% end %>

      <%# ── Google 소셜 회원가입 ── %>
      <% if devise_mapping.omniauthable? && resource_class.omniauth_providers.include?(:google_oauth2) %>
        <div class="devise-separator">
          <span>또는</span>
        </div>

        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, class: "google-login-btn", data: { turbo: false } do %>
          <svg class="google-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Google로 회원가입
        <% end %>
      <% end %>

      <div class="devise-links">
        <%= link_to "이미 계정이 있나요? 로그인", new_session_path(resource_name) %>
      </div>
    </div>
  </div>

  <div class="devise-footer">
    기초생활수급자를 위한 현금흐름 관리 서비스
  </div>
</div>
