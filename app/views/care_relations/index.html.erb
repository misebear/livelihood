<%# ── 보호자 모드 ── %>
<% content_for(:title) { "보호자 관리 — 보듬" } %>
<% content_for(:description) { "가족이나 사회복지사와 보호 관계를 연결해 복지 일정과 현금흐름을 함께 확인하세요." } %>
<% content_for(:canonical_url) { care_relations_url } %>

<div class="mb-4 animate-fade-in-up">
  <h2 class="text-xl font-extrabold text-slate-800 mb-1">보호자 관리</h2>
  <p class="text-sm text-slate-500">가족이나 사회복지사 연결을 관리하세요.</p>
</div>

<% unless user_signed_in? %>
  <section class="auth-gate-card animate-fade-in-up">
    <div class="auth-gate-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
      </svg>
    </div>
    <h3 class="auth-gate-title">로그인하면 보호자 연결을 관리할 수 있어요</h3>
    <p class="auth-gate-desc">보호자 초대, 수락 대기 목록, 대리 조회 권한은 계정에 안전하게 연결됩니다.</p>
    <%= link_to new_user_session_path, class: "btn btn-primary", data: { analytics_event: "login_cta", analytics_category: "care_relations", analytics_label: "guest_gate" } do %>
      로그인하고 보호자 관리하기
    <% end %>
  </section>
<% else %>

<%# ── 보호자로서 돌보는 수급자 목록 ── %>
<section class="care-section animate-fade-in-up stagger-1">
  <div class="care-section-header">
    <div class="care-section-icon violet">
      <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
      </svg>
    </div>
    <h3 class="care-section-title">내가 돌보는 분</h3>
  </div>

  <% if @as_caregiver.any? %>
    <div class="space-y-2">
      <% @as_caregiver.each do |rel| %>
        <div class="care-person-row">
          <div class="care-person-info">
            <div class="care-person-avatar violet">
              <%= (rel.recipient.name || rel.recipient.email[0]).first.upcase %>
            </div>
            <div>
              <p class="care-person-name"><%= rel.recipient.name || rel.recipient.email %></p>
              <span class="status-badge
                <%= rel.accepted? ? 'bg-emerald-100 text-emerald-600' : 'bg-amber-100 text-amber-600' %>">
                <%= rel.accepted? ? '✅ 연결됨' : '⏳ 대기 중' %>
              </span>
            </div>
          </div>
          <div class="care-person-actions">
            <% if rel.accepted? %>
              <%= link_to care_dashboard_path(rel.recipient), class: "care-btn-view" do %>
                📊 대시보드 보기
              <% end %>
            <% end %>
            <%= button_to care_relation_path(rel), method: :delete,
                class: "care-btn-remove",
                data: { turbo_confirm: "보호 관계를 해제할까요?" } do %>
              해제
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state py-4">
      <p class="text-sm text-slate-400">돌보는 분이 없습니다</p>
    </div>
  <% end %>

  <%# 새 수급자 초대 (로그인 시에만) %>
  <% if user_signed_in? %>
    <div class="care-invite-section">
      <p class="care-invite-label">수급자 추가하기</p>
      <%= form_with url: care_relations_path, method: :post, class: "care-invite-form" do |f| %>
        <%= f.email_field :recipient_email, placeholder: "수급자 이메일 입력",
            class: "care-invite-input",
            required: true %>
        <%= f.submit "초대", class: "care-invite-submit" %>
      <% end %>
    </div>
  <% end %>
</section>

<%# ── 나의 보호자 목록 ── %>
<section class="care-section animate-fade-in-up stagger-2">
  <div class="care-section-header">
    <div class="care-section-icon sky">
      <svg class="w-5 h-5 text-sky-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
      </svg>
    </div>
    <h3 class="care-section-title">나의 보호자</h3>
  </div>

  <% if @as_recipient.any? %>
    <div class="space-y-2">
      <% @as_recipient.each do |rel| %>
        <div class="care-person-row">
          <div class="care-person-info">
            <div class="care-person-avatar sky">
              <%= (rel.caregiver.name || rel.caregiver.email[0]).first.upcase %>
            </div>
            <div>
              <p class="care-person-name"><%= rel.caregiver.name || rel.caregiver.email %></p>
              <span class="status-badge
                <%= rel.accepted? ? 'bg-emerald-100 text-emerald-600' : 'bg-amber-100 text-amber-600' %>">
                <%= rel.accepted? ? '✅ 연결됨' : '⏳ 수락 대기' %>
              </span>
            </div>
          </div>
          <div class="care-person-actions">
            <% if rel.pending? %>
              <%= button_to "수락", accept_care_relation_path(rel), method: :patch,
                  class: "care-btn-accept" %>
            <% end %>
            <%= button_to care_relation_path(rel), method: :delete,
                class: "care-btn-remove",
                data: { turbo_confirm: "보호 관계를 해제할까요?" } do %>
              해제
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state py-4">
      <p class="text-sm text-slate-400">등록된 보호자가 없습니다</p>
    </div>
  <% end %>
</section>
<% end %>
