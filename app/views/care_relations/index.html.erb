<%# ── 보호자 모드 ── %>
<% content_for(:title) { "보호자 관리 — 수급생활" } %>

<div class="mb-6">
  <h2 class="text-xl font-extrabold text-slate-800 mb-1">보호자 관리</h2>
  <p class="text-sm text-slate-500">가족이나 사회복지사 연결을 관리하세요.</p>
</div>

<%# ── 보호자로서 돌보는 수급자 목록 ── %>
<section class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 mb-4">
  <div class="flex items-center gap-2 mb-4">
    <div class="w-8 h-8 bg-violet-100 rounded-lg flex items-center justify-center">
      <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
      </svg>
    </div>
    <h3 class="text-sm font-bold text-slate-700">내가 돌보는 분</h3>
  </div>

  <% if @as_caregiver.any? %>
    <div class="space-y-2">
      <% @as_caregiver.each do |rel| %>
        <div class="flex items-center justify-between py-3 px-3 bg-slate-50 rounded-xl">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-violet-200 rounded-full flex items-center justify-center text-sm font-bold text-violet-700">
              <%= (rel.recipient.name || rel.recipient.email[0]).first.upcase %>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-700"><%= rel.recipient.name || rel.recipient.email %></p>
              <span class="text-xs px-2 py-0.5 rounded-full
                <%= rel.accepted? ? 'bg-emerald-100 text-emerald-600' : 'bg-amber-100 text-amber-600' %>">
                <%= rel.accepted? ? '연결됨' : '대기 중' %>
              </span>
            </div>
          </div>
          <%= button_to care_relation_path(rel), method: :delete,
              class: "text-xs text-red-500 hover:text-red-700 transition",
              data: { turbo_confirm: "보호 관계를 해제할까요?" } do %>
            해제
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-400 text-center py-3">돌보는 분이 없습니다.</p>
  <% end %>

  <%# 새 수급자 초대 %>
  <div class="mt-4 pt-4 border-t border-slate-100">
    <p class="text-xs font-bold text-slate-600 mb-2">수급자 추가하기</p>
    <%= form_with url: care_relations_path, method: :post, class: "flex gap-2" do |f| %>
      <%= f.email_field :recipient_email, placeholder: "수급자 이메일 입력",
          class: "flex-1 px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none transition",
          required: true %>
      <%= f.submit "초대", class: "bg-indigo-600 text-white text-sm font-bold px-4 py-2.5 rounded-xl hover:bg-indigo-700 transition cursor-pointer" %>
    <% end %>
  </div>
</section>

<%# ── 나의 보호자 목록 ── %>
<section class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 mb-4">
  <div class="flex items-center gap-2 mb-4">
    <div class="w-8 h-8 bg-sky-100 rounded-lg flex items-center justify-center">
      <svg class="w-5 h-5 text-sky-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
      </svg>
    </div>
    <h3 class="text-sm font-bold text-slate-700">나의 보호자</h3>
  </div>

  <% if @as_recipient.any? %>
    <div class="space-y-2">
      <% @as_recipient.each do |rel| %>
        <div class="flex items-center justify-between py-3 px-3 bg-slate-50 rounded-xl">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-sky-200 rounded-full flex items-center justify-center text-sm font-bold text-sky-700">
              <%= (rel.caregiver.name || rel.caregiver.email[0]).first.upcase %>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-700"><%= rel.caregiver.name || rel.caregiver.email %></p>
              <span class="text-xs px-2 py-0.5 rounded-full
                <%= rel.accepted? ? 'bg-emerald-100 text-emerald-600' : 'bg-amber-100 text-amber-600' %>">
                <%= rel.accepted? ? '연결됨' : '수락 대기' %>
              </span>
            </div>
          </div>
          <div class="flex gap-2">
            <% if rel.pending? %>
              <%= button_to "수락", accept_care_relation_path(rel), method: :patch,
                  class: "text-xs bg-emerald-100 text-emerald-700 font-bold px-3 py-1.5 rounded-lg hover:bg-emerald-200 transition" %>
            <% end %>
            <%= button_to care_relation_path(rel), method: :delete,
                class: "text-xs text-red-500 hover:text-red-700 transition",
                data: { turbo_confirm: "보호 관계를 해제할까요?" } do %>
              해제
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-400 text-center py-3">등록된 보호자가 없습니다.</p>
  <% end %>
</section>

<%= link_to root_path, class: "block text-center text-sm text-slate-500 hover:text-indigo-600 transition" do %>
  ← 대시보드로 돌아가기
<% end %>
