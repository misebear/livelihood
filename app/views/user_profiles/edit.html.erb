<%# ── 내 정보 수정 ── %>
<% content_for(:title) { "내 정보 — 수급생활" } %>

<div class="mb-6">
  <h2 class="text-xl font-extrabold text-slate-800 mb-1">내 상황 입력</h2>
  <p class="text-sm text-slate-500">정확한 안전선 계산을 위해 아래 정보를 입력해 주세요.</p>
</div>

<%= form_with(model: @profile, url: user_profile_path, method: :patch,
    class: "space-y-5") do |f| %>

  <% if @profile.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
      <p class="text-sm font-bold text-red-700 mb-1">입력 오류가 있습니다:</p>
      <ul class="text-sm text-red-600 list-disc list-inside">
        <% @profile.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── 가구 정보 ── %>
  <section class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
    <div class="flex items-center gap-2 mb-4">
      <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
      </div>
      <h3 class="text-sm font-bold text-slate-700">가구 정보</h3>
    </div>

    <div class="space-y-4">
      <div>
        <%= f.label :household_size, "가구원 수", class: "block text-sm font-semibold text-slate-600 mb-1" %>
        <%= f.number_field :household_size, min: 1, max: 7, placeholder: "예: 4",
            class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none transition" %>
        <p class="text-xs text-slate-400 mt-1">본인을 포함한 전체 가구원 수 (최대 7인)</p>
      </div>

      <div>
        <%= f.label :region_type, "거주 지역", class: "block text-sm font-semibold text-slate-600 mb-1" %>
        <%= f.select :region_type,
            [["서울/대도시", "metropolitan"], ["중소도시", "city"], ["농어촌", "rural"]],
            { include_blank: "선택하세요" },
            class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none transition bg-white" %>
      </div>

      <div>
        <%= f.label :housing_type, "주거 형태", class: "block text-sm font-semibold text-slate-600 mb-1" %>
        <%= f.select :housing_type,
            [["자가", "owned"], ["전세", "jeonse"], ["월세", "monthly_rent"], ["공공임대", "public_rental"]],
            { include_blank: "선택하세요" },
            class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none transition bg-white" %>
      </div>
    </div>
  </section>

  <%# ── 소득/재산 정보 ── %>
  <section class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
    <div class="flex items-center gap-2 mb-4">
      <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>
      <h3 class="text-sm font-bold text-slate-700">소득 · 재산 정보</h3>
    </div>

    <div class="bg-amber-50 border border-amber-100 rounded-xl p-3 mb-4">
      <p class="text-xs text-amber-700">🔒 입력하신 정보는 암호화되어 저장됩니다. 안전선 계산에만 사용되며 외부에 공유되지 않습니다.</p>
    </div>

    <div class="space-y-4">
      <div>
        <%= f.label :declared_monthly_income, "월 소득 (원)", class: "block text-sm font-semibold text-slate-600 mb-1" %>
        <%= f.text_field :declared_monthly_income, placeholder: "예: 800000",
            inputmode: "numeric", pattern: "[0-9]*",
            class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none transition" %>
        <p class="text-xs text-slate-400 mt-1">근로소득, 사업소득, 기타소득 합계</p>
      </div>

      <div>
        <%= f.label :declared_assets, "총 재산 (원)", class: "block text-sm font-semibold text-slate-600 mb-1" %>
        <%= f.text_field :declared_assets, placeholder: "예: 30000000",
            inputmode: "numeric", pattern: "[0-9]*",
            class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none transition" %>
        <p class="text-xs text-slate-400 mt-1">예금, 적금, 보험 등 금융재산 합계</p>
      </div>

      <div>
        <%= f.label :vehicle_value, "차량 가액 (원)", class: "block text-sm font-semibold text-slate-600 mb-1" %>
        <%= f.text_field :vehicle_value, placeholder: "없으면 0",
            inputmode: "numeric", pattern: "[0-9]*",
            class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-200 focus:border-indigo-400 outline-none transition" %>
        <p class="text-xs text-slate-400 mt-1">보유 차량이 없으면 0 입력</p>
      </div>
    </div>
  </section>

  <%# ── 제출 ── %>
  <div class="flex gap-3">
    <%= f.submit "저장하기",
        class: "flex-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold py-3 rounded-xl shadow-sm hover:opacity-90 transition text-sm cursor-pointer" %>
    <%= link_to "취소", root_path,
        class: "flex-1 bg-slate-100 text-slate-600 font-bold py-3 rounded-xl text-center hover:bg-slate-200 transition text-sm" %>
  </div>

  <%= render_disclaimer(type: :calculator, css_class: "mb-4") %>
<% end %>
