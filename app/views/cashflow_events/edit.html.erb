<%# ── 현금흐름 이벤트 수정 ── %>
<% content_for(:title) { "이벤트 수정 — 보듬" } %>

<div class="mb-4">
  <%= link_to root_path, class: "inline-flex items-center gap-1 text-sm text-slate-500 hover:text-indigo-600 transition" do %>
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    대시보드로
  <% end %>
</div>

<section class="card">
  <h2 class="card-title mb-2" style="font-size:1.25rem;">이벤트 수정</h2>

  <%= render "form", event: @event %>
</section>
