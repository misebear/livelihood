<%# ── 현금흐름 이벤트 폼 (공용) ── %>

<%= form_with(model: event) do |f| %>
  <% if event.errors.any? %>
    <div class="devise-error-box">
      <p class="devise-error-title">오류가 있습니다:</p>
      <ul class="devise-error-list">
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# 유형 선택 %>
  <div class="field">
    <%= f.label :event_type, "유형" %>
    <div class="grid-2" style="margin-top:0.375rem;">
      <label class="event-type-option">
        <%= f.radio_button :event_type, "payment", checked: event.payment? || event.new_record? %>
        <span class="event-type-label income">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="color:#059669;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          수입
        </span>
      </label>
      <label class="event-type-option">
        <%= f.radio_button :event_type, "deduction" %>
        <span class="event-type-label expense">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="color:#e11d48;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
          </svg>
          지출
        </span>
      </label>
    </div>
  </div>

  <%# 일정 이름 %>
  <div class="field">
    <%= f.label :title, "일정 이름" %>
    <%= f.text_field :title, placeholder: "예: 생계급여, 월세, 자격갱신, 서류제출 등", required: true %>
  </div>

  <%# 날짜 %>
  <div class="field">
    <%= f.label :event_date, "일자" %>
    <%= f.date_field :event_date, required: true %>
  </div>

  <%# 금액 %>
  <div class="field">
    <%= f.label :expected_amount, "예상 금액 (원)" %>
    <%= f.number_field :expected_amount, placeholder: "0", min: 0, step: 1000, required: true %>
  </div>

  <%# ── 일정 분류 (일정 허브) ── %>
  <div class="field">
    <%= f.label :schedule_type, "일정 분류" %>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.375rem;margin-top:0.375rem;">
      <label class="event-type-option">
        <%= f.radio_button :schedule_type, "cashflow", checked: event.schedule_type_cashflow? || event.new_record? %>
        <span class="event-type-label" style="background:#f0fdf4;color:#047857;border-color:#a7f3d0;">💰 현금흐름</span>
      </label>
      <label class="event-type-option">
        <%= f.radio_button :schedule_type, "renewal" %>
        <span class="event-type-label" style="background:#fef3c7;color:#92400e;border-color:#fde68a;">📋 자격 갱신</span>
      </label>
      <label class="event-type-option">
        <%= f.radio_button :schedule_type, "document" %>
        <span class="event-type-label" style="background:#eef2ff;color:#3730a3;border-color:#c7d2fe;">📄 서류 제출</span>
      </label>
      <label class="event-type-option">
        <%= f.radio_button :schedule_type, "appointment" %>
        <span class="event-type-label" style="background:#fdf2f8;color:#9d174d;border-color:#fbcfe8;">📅 상담 예약</span>
      </label>
    </div>
  </div>

  <%# 중요 일정 체크 %>
  <div class="field" style="display:flex;align-items:center;gap:0.5rem;">
    <%= f.check_box :is_critical, style: "width:18px;height:18px;accent-color:#ef4444;" %>
    <%= f.label :is_critical, "🔴 놓치면 수급에 영향이 있는 중요 일정", style: "font-size:0.8125rem;font-weight:600;color:#991b1b;" %>
  </div>

  <%# 메모 %>
  <div class="field">
    <%= f.label :memo, "메모 (선택)" %>
    <%= f.text_area :memo, placeholder: "준비물, 주의사항 등을 메모하세요", rows: 2, style: "resize:vertical;" %>
  </div>

  <div class="actions" style="margin-top:1rem;">
    <%= f.submit event.persisted? ? "수정 완료" : "이벤트 추가", class: "btn btn-primary btn-full" %>
  </div>
<% end %>
